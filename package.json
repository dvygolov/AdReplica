{
  "name": "adreplica",
  "version": "240626b1",
  "private": true,
  "description": "Browser-side Facebook Ads Manager export, import, clone, and bookmarklet loader tooling.",
  "scripts": {
    "bump:build": "node scripts/bump-build-version.cjs",
    "build:payload": "node scripts/build-payload.cjs",
    "check:payload": "node scripts/build-payload.cjs --check",
    "check": "npm run check:payload && node --check adreplica-og-packager.js && node --check adreplica.js && node --check adreplica-loader.js",
    "prebuild": "npm run bump:build",
    "build": "npm run build:payload && node adreplica-og-packager.js --base-url=https://adreplica.pages.dev/adreplica",
    "deploy": "npx wrangler pages deploy ./dist --project-name=adreplica --branch=main --commit-dirty=true"
  },
  "keywords": [
    "facebook-ads",
    "ads-manager",
    "bookmarklet",
    "campaign-clone"
  ],
  "author": "Yellow Web",
  "license": "UNLICENSED",
  "devDependencies": {
    "esbuild": "^0.25.5"
  }
}
